/* LinkedIn Networking CLI — Textual TUI layout (issue #24).
 *
 * Single source of *structure* truth: spacing, elevation, focus, grids. Colour
 * comes from the registered "linkedin" Theme (src/tui/theme.py) via semantic
 * tokens ($primary, $panel, $text-muted, $surface-2 …) — never raw hex here.
 *
 * Design language (modern terminal, 2025/2026): separation comes from
 * *elevation* (surface → panel) and *whitespace*, not boxed borders. Every
 * screen opens with the same brand masthead (the `in` badge) and closes with
 * the same dim hint bar, all on a shared left margin, so the app reads as one
 * piece. The brand blue is the identity (solid fills, focus); a brighter blue
 * carries text accents. SCREEN_GUTTER (the 4-column side margin) is applied
 * consistently to the masthead, bodies, and hint bar.
 */

Screen {
    background: $surface;
}

/* Thin, muted scrollbars everywhere — a quiet thumb that brightens to the
 * accent on interaction, instead of Textual's bright default. Applied
 * universally so nested scrollables (forms, logs, select overlays) don't
 * regress to the loud default track. */
* {
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 1;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface;
    scrollbar-color: $panel-lighten-2;
    scrollbar-color-hover: $primary;
    scrollbar-color-active: $secondary;
}

/* ── Shared frame ─────────────────────────────────────────────────────── */

/* The brand masthead at the top of every sub-screen: `in  LinkedIn  ·  Title`,
 * on the shared gutter, with breathing room before the body. */
.masthead {
    height: auto;
    padding: 1 4 0 4;
    margin: 0 0 1 0;
}

/* Eyebrow: a small, dim, upper-case label that introduces a region (matches the
 * home's NAVIGATE label). */
.eyebrow {
    color: $text-disabled;
    text-style: bold;
    margin: 1 0 0 0;
}

/* The status line every data screen uses for loading / empty / error /
 * degraded messages — designed states, never a raw traceback. */
.status-line {
    color: $text-muted;
    padding: 0 4;
}

/* Dim hint bar at the foot — Claude-Code-style `key action · …`, recessed. */
.hint-bar {
    height: 1;
    padding: 0 4;
    margin: 1 0 0 0;
}

/* Modern table: no wrapping box — the bright cursor row carries focus, a quiet
 * muted header carries structure, and a barely-there zebra (surface vs the
 * one-step panel) replaces the harsh stripe. */
DataTable {
    background: $surface;
    border: none;
}
DataTable > .datatable--header {
    background: $surface;
    color: $text-muted;
    text-style: bold;
}

/* Muted selection (Claude Code uses a desaturated selection blue, not a bright
 * brand bar): a low-alpha brand tint keeps the row calm but clearly current. */
DataTable > .datatable--cursor {
    background: $primary 30%;
    color: $foreground;
    text-style: bold;
}

DataTable > .datatable--hover {
    background: $surface-lighten-1;
}

DataTable > .datatable--even-row {
    background: $panel;
}

/* ── Home launcher ────────────────────────────────────────────────────── */

#home {
    height: 1fr;
    /* Top/bottom kept to 1: the hero mascot is 21 rows tall, and with the
     * nav below the whole home must land inside 40 terminal rows. */
    padding: 1 4;
}

/* Hero: the mascot beside the wordmark / tagline / summary. */
#home-hero {
    height: auto;
    margin-bottom: 1;
}

#home-mascot {
    width: auto;
    /* No bold: synthetic-bold doubles the block glyphs (offset + subpixel-AA
     * colour fringing). The sprite's solid fills need no weight. */
    text-style: none;
    padding: 0 3 0 0;
}

#home-heading {
    width: 1fr;
    /* Content column beside the mascot: lockup on top, navigation beneath. */
    height: auto;
}

/* Space between the lockup's status line and the NAVIGATE eyebrow. */
#home-nav-eyebrow {
    margin-top: 1;
}

/* Letterspaced small-caps brand line above the big wordmark. */
#home-eyebrow {
    color: $text-muted;
    margin-bottom: 1;
}

/* Large "NETWORKING" type — half-block pixel art, same language as the
 * mascot. No bold: synthetic-bold doubles block glyphs (offset + colour
 * fringing), exactly as on the mascot above. Colour comes inline. */
#home-wordmark {
    text-style: none;
}

/* Plain-text stand-in shown when the terminal is too narrow for the pixel
 * type (HomeScreen toggles .narrow on resize). */
#home-wordmark-fallback {
    display: none;
    color: $primary-lighten-2;
}

HomeScreen.narrow #home-wordmark {
    display: none;
}

HomeScreen.narrow #home-wordmark-fallback {
    display: block;
}

#home-tagline {
    color: $text-muted;
    margin-top: 1;
}

/* Live one-line workspace summary in the hero (worker-populated). */
#home-status {
    color: $text-muted;
    margin: 1 0 0 0;
}

#home-nav {
    width: 1fr;
    max-width: 76;
    height: auto;
    background: transparent;
    border: none;
    padding: 0;
}

#home-nav:focus {
    border: none;
}

/* Selection is a `❯` pointer + recoloured title (Claude Code's idiom): no
 * background bar, no border. The override is ID-scoped so it beats Textual's
 * block-cursor default (`ListView:focus > ListItem.-highlight`). */
#home-nav > ListItem {
    height: auto;
    padding: 0 0 1 0;
    background: transparent;
    color: $foreground;
}

#home-nav > ListItem.-highlight,
#home-nav:focus > ListItem.-highlight {
    background: transparent;
    color: $foreground;
    text-style: none;
}

.nav-row {
    height: auto;
}

/* The pointer is reserved on every row (width 2) but coloured like the surface
 * so it's invisible until the row is highlighted. */
.nav-caret {
    width: 2;
    color: $surface;
    text-style: bold;
}

.nav-title {
    text-style: bold;
    color: $foreground;
}

/* Description sits under the title, indented past the reserved pointer column.
 * Width 1fr (not auto) so it wraps inside the hero's content column instead of
 * clipping at the screen edge on narrower terminals. */
.nav-desc {
    width: 1fr;
    color: $text-muted;
    padding: 0 0 0 2;
}

#home-nav > ListItem.-highlight .nav-caret {
    color: $secondary;
}

#home-nav > ListItem.-highlight .nav-title {
    color: $secondary;
}

/* Mouse affordance: hovering a row hints the pointer without stealing the
 * keyboard highlight's stronger accent. */
#home-nav > ListItem.-hovered .nav-caret {
    color: $text-muted;
}

/* ── Campaigns screen ─────────────────────────────────────────────────── */

#campaigns-table {
    margin: 1 4;
    height: 1fr;
}

/* New Campaign / Refresh: visible, focusable buttons below the table (owner
 * rule, 2026-07-09) — tab + Enter reach them; n/r remain accelerators. */
#campaigns-toolbar {
    height: auto;
    margin: 0 4 1 4;
}

#campaigns-toolbar Button {
    margin-right: 2;
}

/* ── Dashboard screen ─────────────────────────────────────────────────── */

#dashboard-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* Two rows of three borderless stat tiles, separated by gutters over the
 * screen surface — elevation, not outlines. */
#stat-grid {
    grid-size: 3;
    grid-gutter: 1 2;
    grid-rows: 5;
    height: auto;
    /* The OVERVIEW eyebrow above provides the top gap. */
    margin: 0 0 1 0;
}

.stat-card {
    background: $panel;
    height: 5;
    padding: 1 2;
}

.stat-label {
    color: $text-muted;
}

.stat-value {
    text-style: bold;
    color: $foreground;
}

.stat-value.-good {
    color: $success;
}

.stat-value.-warn {
    color: $warning;
}

#dashboard-recent {
    height: auto;
    max-height: 14;
    /* The RECENT CAMPAIGNS eyebrow above provides the top gap. */
    margin-top: 0;
}

/* Refresh: a visible, focusable button below the table (owner rule,
 * 2026-07-09) — tab + Enter reach it; r remains an accelerator. */
#dashboard-refresh {
    margin: 1 0 0 0;
}

/* ── Settings screen ──────────────────────────────────────────────────── */

#settings-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* Elevated panels, no outline — elevation + the bold title do the framing. */
.settings-section {
    background: $panel;
    height: auto;
    padding: 1 2;
    margin-bottom: 1;
}

/* Refresh: this screen's sole focusable widget (owner rule, 2026-07-09) — tab +
 * Enter reach it; r remains an accelerator. */
#settings-refresh {
    margin: 1 0 0 0;
}

.settings-section-title {
    text-style: bold;
    color: $foreground;
    margin-bottom: 1;
}

/* ── Campaign form (Create + Edit share #form-body) ───────────────────── */

#form-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* A dim caption above each field — the same quiet voice as the eyebrows and
 * stat labels, so the form reads as part of the same calm surface. */
.field-label {
    color: $text-muted;
    margin: 1 0 0 0;
}

/* Constrain fields to a comfortable measure (matching the home nav width)
 * rather than stretching edge-to-edge on a wide terminal. Fields are *filled*
 * (elevated panel over the surface — the app's own elevation language), not
 * outlined boxes: a quiet left accent rule marks the field and lights up
 * brand-blue on focus, the one place the identity colour earns its keep. */
#form-body Input,
#form-body Select,
#run-body Input,
#run-body Select {
    width: 76;
    border: none;
    border-left: thick $panel-lighten-2;
    background: $panel;
    padding: 0 1;
}

/* Compact single-row inputs (the default is a 3-row bordered box; with the
 * border gone the extra rows just read as dead air). */
#form-body Input,
#run-body Input {
    height: 1;
}
#form-body Input:focus,
#form-body Select:focus,
#run-body Input:focus,
#run-body Select:focus {
    border-left: thick $primary;
    background: $panel-lighten-1;
}
Select SelectCurrent {
    border: none;
    background: transparent;
    padding: 0;
}

/* The dropdown list: an elevated panel that hugs the field (no loud brand
 * border, no full-width spill), with the same muted selection tint the tables
 * use — one selection idiom across the app. */
SelectOverlay {
    background: $panel;
    border: round $panel-lighten-2;
    max-height: 14;
    padding: 0;
}
SelectOverlay > .option-list--option-highlighted {
    background: $primary 25%;
    color: $foreground;
    text-style: bold;
}

/* Location search / custom-geoUrn widgets start hidden; the Location select's
 * sentinel options reveal them (widget.display toggles inline, which wins). */
.loc-conditional {
    display: none;
}

/* Create/Save: a visible, focusable button below the fields (owner rule,
 * 2026-07-09) — tab + Enter reach it; ctrl+s remains an accelerator. Left/right
 * margin matches #form-body's own gutter since the button is a sibling, not a
 * child, of that scroll container. */
#form-submit {
    margin: 1 4 0 4;
}

/* ── Campaign detail screen (issue #42: the campaign's action hub) ─────── */

/* Two columns: configuration/performance on the left, the ACTIONS list and
 * the embedded run panel (the streaming log surface) on the right. */
#detail-columns {
    height: 1fr;
    padding: 0 4;
}

#detail-body {
    width: 1fr;
    height: 1fr;
    overflow-y: auto;
    margin-right: 2;
}

#detail-side {
    width: 1fr;
    height: 1fr;
}

/* The detail's action list mirrors the home nav idiom: a `❯` pointer + the
 * recoloured title carry the selection — no background bar, no border. */
#detail-actions {
    height: auto;
    background: transparent;
    border: none;
    padding: 0;
    margin-bottom: 1;
}

#detail-actions:focus {
    border: none;
}

#detail-actions > ListItem {
    height: auto;
    background: transparent;
    color: $foreground;
}

#detail-actions > ListItem.-highlight,
#detail-actions:focus > ListItem.-highlight {
    background: transparent;
    color: $foreground;
    text-style: none;
}

#detail-actions > ListItem.-highlight .nav-caret {
    color: $secondary;
}

#detail-actions > ListItem.-highlight .nav-title {
    color: $secondary;
}

#detail-actions > ListItem.-hovered .nav-caret {
    color: $text-muted;
}

/* The embedded run panel fills the right column's remaining space; the run
 * screens' full-width panel keeps the shared gutter instead. */
#detail-run-panel {
    height: 1fr;
}

/* ── Automation run surfaces (run panel + AutomationRunScreen hosts) ──── */

#run-body {
    height: auto;
    max-height: 50%;
    overflow-y: auto;
    padding: 0 4;
}

#run-panel {
    height: 1fr;
    padding: 0 4;
}

/* The panel supplies its own gutter (or the detail column does), so its
 * status line drops the screen-level status padding. */
AutomationRunPanel .status-line {
    padding: 0;
}

/* The streaming progress log — an elevated panel, revealed only once a run
 * starts (hidden while idle so the selection/actions have room). */
#run-log {
    height: 1fr;
    min-height: 10;
    margin: 1 0 0 0;
    padding: 1 2;
    background: $panel;
    border: none;
}

/* The run controls — Start (#run-start), the inline confirm's buttons, and
 * the stop control (issue #43), each revealed when relevant and focusable so
 * arrows/tab + Enter drive the whole flow. The same field idiom as the inputs
 * (flat elevated panel, left accent rule that lights up brand-blue on focus)
 * rather than Textual's chunky default button. */
#run-start,
#run-stop,
ConfirmBar Button {
    width: auto;
    height: 1;
    min-width: 0;
    padding: 0 2;
    border: none;
    border-left: thick $panel-lighten-2;
    background: $panel;
    color: $text;
    text-style: none;
}
#run-start:focus,
#run-stop:focus,
ConfirmBar Button:focus {
    border-left: thick $primary;
    background: $panel-lighten-1;
    text-style: bold;
}
#run-start:disabled,
#run-stop:disabled {
    color: $text-muted;
}

#run-start {
    margin: 1 0 0 0;
}

/* The inline confirmation: a focused confirm button beside Cancel. */
ConfirmBar {
    height: 1;
    margin: 0 0 1 0;
}
ConfirmBar .confirm-no {
    margin-left: 2;
}

/* ── Flat action buttons (shared idiom, owner rule 2026-07-09) ──────────── */

/* Every action that used to be key-only (New/Refresh/Save/Create) is now a
 * visible, focusable button — reusing the exact same flat, left-accent-rule
 * idiom as the automation run controls (#run-start, #run-stop, ConfirmBar
 * Button above) so the whole app reads as one design language. */
.flat-button {
    width: auto;
    height: 1;
    min-width: 0;
    padding: 0 2;
    border: none;
    border-left: thick $panel-lighten-2;
    background: $panel;
    color: $text;
    text-style: none;
}
.flat-button:focus {
    border-left: thick $primary;
    background: $panel-lighten-1;
    text-style: bold;
}
.flat-button:disabled {
    color: $text-muted;
}

/* ── Shared status-line semantics (forms, detail, automation) ─────────── */

/* The status line carries validation / write / progress feedback in the
 * semantic colour; reused by every screen that reports an outcome inline. */
.status-line.-good {
    color: $success;
}
.status-line.-warn {
    color: $warning;
}
.status-line.-error {
    color: $error;
}
