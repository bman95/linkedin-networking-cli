/* LinkedIn Networking CLI — Textual TUI layout (issue #24).
 *
 * Single source of *structure* truth: spacing, elevation, focus, grids. Colour
 * comes from the registered "linkedin" Theme (src/tui/theme.py) via semantic
 * tokens ($primary, $panel, $text-muted, $surface-2 …) — never raw hex here.
 *
 * Design language (modern terminal, 2025/2026): separation comes from
 * *elevation* (surface → panel) and *whitespace*, not boxed borders. Every
 * screen opens with the same brand masthead (the `in` badge) and closes with
 * the same dim hint bar, all on a shared left margin, so the app reads as one
 * piece. The brand blue is the identity (solid fills, focus); a brighter blue
 * carries text accents. SCREEN_GUTTER (the 4-column side margin) is applied
 * consistently to the masthead, bodies, and hint bar.
 */

Screen {
    background: $surface;
    /* Thin, muted scrollbars — a quiet thumb that brightens to the accent on
     * interaction, instead of Textual's bright default. */
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 1;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface;
    scrollbar-color: $text-disabled;
    scrollbar-color-hover: $primary;
    scrollbar-color-active: $secondary;
}

/* ── Shared frame ─────────────────────────────────────────────────────── */

/* The brand masthead at the top of every sub-screen: `in  LinkedIn  ·  Title`,
 * on the shared gutter, with breathing room before the body. */
.masthead {
    height: auto;
    padding: 1 4 0 4;
    margin: 0 0 1 0;
}

/* Eyebrow: a small, dim, upper-case label that introduces a region (matches the
 * home's NAVIGATE label). */
.eyebrow {
    color: $text-disabled;
    text-style: bold;
    margin: 1 0 0 0;
}

/* The status line every data screen uses for loading / empty / error /
 * degraded messages — designed states, never a raw traceback. */
.status-line {
    color: $text-muted;
    padding: 0 4;
}

/* Dim hint bar at the foot — Claude-Code-style `key action · …`, recessed. */
.hint-bar {
    height: 1;
    padding: 0 4;
    margin: 1 0 0 0;
}

/* Modern table: no wrapping box — the bright cursor row carries focus, a quiet
 * muted header carries structure, and a barely-there zebra (surface vs the
 * one-step panel) replaces the harsh stripe. */
DataTable {
    background: $surface;
    border: none;
}
DataTable > .datatable--header {
    background: $surface;
    color: $text-muted;
    text-style: bold;
}

/* Muted selection (Claude Code uses a desaturated selection blue, not a bright
 * brand bar): a low-alpha brand tint keeps the row calm but clearly current. */
DataTable > .datatable--cursor {
    background: $primary 30%;
    color: $foreground;
    text-style: bold;
}

DataTable > .datatable--hover {
    background: $surface-lighten-1;
}

DataTable > .datatable--even-row {
    background: $panel;
}

/* ── Home launcher ────────────────────────────────────────────────────── */

#home {
    height: 1fr;
    padding: 2 4;
}

/* Hero: the mascot beside the wordmark / tagline / summary. */
#home-hero {
    height: auto;
    margin-bottom: 1;
}

#home-mascot {
    width: auto;
    text-style: bold;
    padding: 0 3 0 0;
}

#home-heading {
    width: 1fr;
    height: auto;
    /* Nudge the text block down so it sits centred against the 6-row mascot. */
    padding: 1 0 0 0;
}

#home-wordmark {
    text-style: bold;
}

#home-tagline {
    color: $text-muted;
}

/* Live one-line workspace summary in the hero (worker-populated). */
#home-status {
    color: $text-muted;
    margin: 1 0 0 0;
}

#home-nav {
    width: 1fr;
    max-width: 76;
    height: auto;
    background: transparent;
    border: none;
    padding: 0;
}

#home-nav:focus {
    border: none;
}

/* Selection is a `❯` pointer + recoloured title (Claude Code's idiom): no
 * background bar, no border. The override is ID-scoped so it beats Textual's
 * block-cursor default (`ListView:focus > ListItem.-highlight`). */
#home-nav > ListItem {
    height: auto;
    padding: 0 0 1 0;
    background: transparent;
    color: $foreground;
}

#home-nav > ListItem.-highlight,
#home-nav:focus > ListItem.-highlight {
    background: transparent;
    color: $foreground;
    text-style: none;
}

.nav-row {
    height: auto;
}

/* The pointer is reserved on every row (width 2) but coloured like the surface
 * so it's invisible until the row is highlighted. */
.nav-caret {
    width: 2;
    color: $surface;
    text-style: bold;
}

.nav-title {
    text-style: bold;
    color: $foreground;
}

/* Description sits under the title, indented past the reserved pointer column. */
.nav-desc {
    color: $text-muted;
    padding: 0 0 0 2;
}

#home-nav > ListItem.-highlight .nav-caret {
    color: $secondary;
}

#home-nav > ListItem.-highlight .nav-title {
    color: $secondary;
}

/* Mouse affordance: hovering a row hints the pointer without stealing the
 * keyboard highlight's stronger accent. */
#home-nav > ListItem.-hovered .nav-caret {
    color: $text-muted;
}

/* ── Campaigns screen ─────────────────────────────────────────────────── */

#campaigns-table {
    margin: 1 4;
    height: 1fr;
}

/* ── Dashboard screen ─────────────────────────────────────────────────── */

#dashboard-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* Two rows of three borderless stat tiles, separated by gutters over the
 * screen surface — elevation, not outlines. */
#stat-grid {
    grid-size: 3;
    grid-gutter: 1 2;
    grid-rows: 5;
    height: auto;
    /* The OVERVIEW eyebrow above provides the top gap. */
    margin: 0 0 1 0;
}

.stat-card {
    background: $panel;
    height: 5;
    padding: 1 2;
}

.stat-label {
    color: $text-muted;
}

.stat-value {
    text-style: bold;
    color: $foreground;
}

.stat-value.-good {
    color: $success;
}

.stat-value.-warn {
    color: $warning;
}

#dashboard-recent {
    height: auto;
    max-height: 14;
    /* The RECENT CAMPAIGNS eyebrow above provides the top gap. */
    margin-top: 0;
}

/* ── Settings screen ──────────────────────────────────────────────────── */

#settings-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* Elevated panels, no outline — elevation + the bold title do the framing. */
.settings-section {
    background: $panel;
    height: auto;
    padding: 1 2;
    margin-bottom: 1;
}

.settings-section-title {
    text-style: bold;
    color: $foreground;
    margin-bottom: 1;
}

/* ── Campaign form (Create + Edit share #form-body) ───────────────────── */

#form-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* A dim caption above each field — the same quiet voice as the eyebrows and
 * stat labels, so the form reads as part of the same calm surface. */
.field-label {
    color: $text-muted;
    margin: 1 0 0 0;
}

/* Constrain fields to a comfortable measure (matching the home nav width)
 * rather than stretching edge-to-edge on a wide terminal. A quiet round border
 * (calmer than Textual's default heavy `tall` edge) tints to the brand blue on
 * focus, the one place the identity colour earns its keep. */
#form-body Input,
#form-body Select {
    width: 76;
    border: round $panel-lighten-2;
    background: $surface;
}
#form-body Input:focus,
#form-body Select:focus {
    border: round $primary;
}
#form-body Select SelectCurrent {
    border: none;
}
#form-body Select SelectOverlay {
    background: $panel;
}

/* ── Campaign detail screen ───────────────────────────────────────────── */

#detail-body {
    height: 1fr;
    overflow-y: auto;
    padding: 0 4;
}

/* ── Shared status-line semantics (forms, detail, automation) ─────────── */

/* The status line carries validation / write / progress feedback in the
 * semantic colour; reused by every screen that reports an outcome inline. */
.status-line.-good {
    color: $success;
}
.status-line.-warn {
    color: $warning;
}
.status-line.-error {
    color: $error;
}
